{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "../../dist/out-tsc/benchmark-core",
        "composite": true,
        "declaration": true,
        "target": "es2020",
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "experimentalDecorators": true,
        "useDefineForClassFields": false,
        "types": ["node", "reflect-metadata"]
    },
    "include": ["src/**/*.ts"],
    "references": []
}
