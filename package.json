{
  "name": "automapper",
  "version": "8.8.1",
  "license": "MIT",
  "scripts": {
    "commit": "git-cz",
    "contributors:init": "all-contributors init",
    "contributors:add": "all-contributors add",
    "release": "dotenv release-it --",
    "release:beta": "dotenv release-it -- major --preRelease=beta",
    "test": "nx run-many --all --target=test --parallel",
    "typecheck": "tsc -b tsconfig.json",
    "package": "nx run-many --target=package-lib --all && nx run zod:build && node tools/scripts/finalize-dist.mjs",
    "package:no-cache": "nx run-many --target=package-lib --all --skip-nx-cache && nx run zod:build --skip-nx-cache && node tools/scripts/finalize-dist.mjs",
    "publish": "nx run-many --target=publish --all --parallel"
  },
  "private": true,
  "dependencies": {
    "@swc/helpers": "0.5.9",
    "tslib": "~2.5.0"
  },
  "devDependencies": {
    "@mikro-orm/core": "5.6.13",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "^11.0.0",
    "@nx/devkit": "22.2.5",
    "@nx/eslint-plugin": "22.2.5",
    "@nx/js": "22.2.5",
    "@nx/nest": "22.2.5",
    "@nx/rollup": "22.2.5",
    "@nx/vitest": "22.2.5",
    "@nx/web": "22.2.5",
    "@nx/workspace": "22.2.5",
    "@release-it/bumper": "4.0.2",
    "@release-it/conventional-changelog": "5.1.1",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.3.99",
    "@types/node": "20.19.9",
    "@types/supertest": "2.0.12",
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "all-contributors-cli": "6.24.0",
    "babel-preset-minify": "0.5.2",
    "commitizen": "4.3.0",
    "cz-customizable": "7.0.0",
    "dotenv-cli": "7.0.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.0.1",
    "fs-extra": "^11.1.0",
    "nx": "22.2.5",
    "prettier": "2.8.4",
    "reflect-metadata": "0.2.2",
    "release-it": "15.8.0",
    "rxjs": "~7.8.0",
    "sequelize": "6.29.2",
    "supertest": "6.3.3",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.50.0",
    "unplugin-swc": "^1.5.9",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    }
  }
}
