{
  "name": "@automapper/classes",
  "version": "8.8.1",
  "main": "./index.cjs.js",
  "module": "./index.esm.js",
  "types": "./src/index.d.ts",
  "peerDependencies": {
    "@automapper/core": "workspace:*",
    "reflect-metadata": "~0.1.13 || ^0.2.0"
  },
  "devDependencies": {
    "@automapper/core": "workspace:*"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.d.ts",
      "import": {
        "types": "./src/index.d.ts",
        "default": "./index.esm.js"
      },
      "require": {
        "types": "./src/index.d.ts",
        "default": "./index.cjs.js"
      },
      "default": "./index.esm.js"
    },
    "./transformer-plugin": {
      "development": "./transformer-plugin/src/index.ts",
      "types": "./transformer-plugin/index.d.ts",
      "import": {
        "types": "./transformer-plugin/index.d.ts",
        "default": "./transformer-plugin/index.esm.js"
      },
      "require": {
        "types": "./transformer-plugin/index.d.ts",
        "default": "./transformer-plugin/index.cjs.js"
      },
      "default": "./transformer-plugin/index.esm.js"
    },
    "./mapped-types": {
      "development": "./mapped-types/src/index.ts",
      "types": "./mapped-types/index.d.ts",
      "import": {
        "types": "./mapped-types/index.d.ts",
        "default": "./mapped-types/index.esm.js"
      },
      "require": {
        "types": "./mapped-types/index.d.ts",
        "default": "./mapped-types/index.cjs.js"
      },
      "default": "./mapped-types/index.esm.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nartc/mapper/tree/main/packages/classes"
  },
  "author": {
    "name": "Chau Tran",
    "email": "nartc7789@gmail.com",
    "url": "https://nartc.me"
  },
  "description": "AutoMapper TypeScript Classes strategy",
  "keywords": [
    "typescript",
    "automapper",
    "mapper",
    "nx"
  ],
  "license": "MIT",
  "files": [
    "**/*"
  ],
  "nx": {
    "name": "classes",
    "tags": [
      "classes"
    ],
    "targets": {
      "package": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "nx package-lib classes",
            "tsc packages/classes/shim/index.ts --outDir dist/packages/classes/shim/"
          ],
          "parallel": false
        }
      },
      "package-lib": {
        "executor": "@nx/rollup:rollup",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "project": "packages/classes/package.json",
          "outputPath": "dist/packages/classes",
          "entryFile": "packages/classes/src/index.ts",
          "tsConfig": "packages/classes/tsconfig.build.json",
          "assets": [
            "packages/classes/src/README.md"
          ],
          "compiler": "babel",
          "external": [
            "typescript",
            "tslib",
            "@automapper/core"
          ],
          "format": [
            "cjs",
            "esm"
          ],
          "updateBuildableProjectDepsInPackageJson": false,
          "babelUpwardRootMode": true
        }
      },
      "lint": {
        "executor": "@nx/eslint:lint",
        "outputs": [
          "{options.outputFile}"
        ],
        "options": {
          "lintFilePatterns": [
            "packages/classes/**/*.ts"
          ]
        }
      },
      "test": {
        "executor": "@nx/vitest:test",
        "outputs": [
          "{workspaceRoot}/coverage/{projectRoot}"
        ],
        "options": {
          "config": "packages/classes/vitest.config.mts",
          "passWithNoTests": true
        },
        "configurations": {
          "ci": {
            "coverage": true
          }
        }
      },
      "publish": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm publish",
          "cwd": "dist/packages/classes"
        }
      }
    }
  }
}
