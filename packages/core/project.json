{
    "name": "core",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/core/src",
    "projectType": "library",
    "tags": ["core"],
    "targets": {
        "package": {
            "executor": "nx:run-commands",
            "outputs": ["{workspaceRoot}/dist/packages/core"],
            "options": {
                "command": "node tools/scripts/build-packages.mjs core"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/packages/core"],
            "options": {
                "jestConfig": "packages/core/jest.config.cjs"
            }
        },
        "publish": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm publish --tag alpha",
                "cwd": "dist/packages/core"
            }
        }
    }
}
