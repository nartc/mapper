{
    "name": "classes",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/classes/src",
    "projectType": "library",
    "tags": [
        "classes"
    ],
    "targets": {
        "package": {
            "executor": "nx:run-commands",
            "outputs": [
                "{workspaceRoot}/dist/packages/classes"
            ],
            "options": {
                "command": "node tools/scripts/build-packages.mjs classes"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": [
                "{workspaceRoot}/coverage/packages/classes"
            ],
            "options": {
                "jestConfig": "packages/classes/jest.config.cjs"
            }
        },
        "publish": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm publish --tag alpha",
                "cwd": "dist/packages/classes"
            }
        },
        "nx-release-publish": {
            "executor": "@nx/js:release-publish",
            "options": {
                "packageRoot": "dist/packages/classes"
            }
        }
    }
}
