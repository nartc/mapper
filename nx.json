{
    "extends": "nx/presets/core.json",
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "plugins": [
        {
            "plugin": "@nx/js/typescript"
        }
    ],
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "shared"],
        "prod": ["!{projectRoot}/**/*.spec.ts"],
        "shared": ["{workspaceRoot}/.github/workflows/ci.yml"]
    },
    "targetDefaults": {
        "build": { "cache": true },
        "package": {
            "cache": true,
            "inputs": [
                "default",
                "^default",
                "{workspaceRoot}/tools/scripts/build-packages.mjs"
            ]
        },
        "package-lib": { "cache": true },
        "test": { "inputs": ["default", "^prod"], "cache": true },
        "@nx/eslint:lint": {
            "inputs": [
                "default",
                "^default",
                "{workspaceRoot}/.eslintrc.json",
                "{workspaceRoot}/tools/eslint-rules/**/*"
            ],
            "cache": true
        }
    },
    "release": {
        "projects": [
            "core",
            "classes",
            "pojos",
            "nestjs",
            "mikro",
            "sequelize"
        ],
        "version": {
            "preVersionCommand": "pnpm package",
            "currentVersionResolver": "git-tag",
            "preserveLocalDependencyProtocols": false,
            "manifestRootsToUpdate": ["dist/packages/{projectName}"]
        },
        "conventionalCommits": {
            "types": {
                "refactor": {
                    "changelog": true,
                    "semverBump": "patch"
                },
                "perf": {
                    "changelog": true,
                    "semverBump": "patch"
                }
            }
        },
        "changelog": {
            "workspaceChangelog": { "createRelease": "github" }
        }
    },
    "pluginsConfig": { "@nx/js": { "analyzeSourceFiles": true } },
    "defaultBase": "main",
    "analytics": false,
    "nxCloudId": "6a3e997e7427195a38f6bdbc",
    "bust": "2"
}
