{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc/nestjs/lib",
        "composite": true,
        "declaration": true,
        "types": [],
        "target": "es2021",
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["**/*.spec.ts", "**/*.test.ts"],
    "references": [
        {
            "path": "../core/tsconfig.lib.json"
        }
    ]
}
