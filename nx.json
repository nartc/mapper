{
    "extends": "nx/presets/core.json",
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "plugins": [
        {
            "plugin": "@nx/js/typescript",
            "exclude": ["packages/benchmark-core/*"]
        }
    ],
    "namedInputs": {
        "default": ["{projectRoot}/**/*"],
        "prod": ["!{projectRoot}/**/*.spec.ts"]
    },
    "targetDefaults": {
        "build": { "cache": true },
        "package": {
            "cache": true,
            "inputs": [
                "default",
                "^default",
                "{workspaceRoot}/tools/scripts/build-packages.mjs"
            ]
        },
        "package-lib": { "cache": true },
        "test": { "inputs": ["default", "^prod"], "cache": true },
        "@nx/eslint:lint": {
            "inputs": [
                "default",
                "^default",
                "{workspaceRoot}/.eslintrc.json",
                "{workspaceRoot}/tools/eslint-rules/**/*"
            ],
            "cache": true
        }
    },
    "release": {
        "projects": [
            "core",
            "classes",
            "pojos",
            "nestjs",
            "mikro",
            "sequelize"
        ],
        "projectsRelationship": "independent",
        "releaseTagPattern": "{projectName}@{version}",
        "version": {
            "conventionalCommits": true,
            "preserveLocalDependencyProtocols": true
        },
        "changelog": {
            "automaticFromRef": true,
            "projectChangelogs": { "createRelease": "github" }
        }
    },
    "pluginsConfig": { "@nx/js": { "analyzeSourceFiles": true } },
    "defaultBase": "main",
    "analytics": false,
    "nxCloudId": "6a3e997e7427195a38f6bdbc"
}
