{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc/classes/lib",
        "composite": true,
        "declaration": true,
        "types": ["node"]
    },
    "include": ["src/**/*.ts"],
    "exclude": [
        "**/*.spec.ts",
        "**/*.test.ts",
