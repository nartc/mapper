{
    "name": "nestjs",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/nestjs/src",
    "tags": ["nestjs"],
    "targets": {
        "package": {
            "executor": "nx:run-commands",
            "outputs": ["{workspaceRoot}/dist/packages/nestjs"],
            "options": {
                "command": "node tools/scripts/build-packages.mjs nestjs"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/packages/nestjs"],
            "options": {
                "jestConfig": "packages/nestjs/jest.config.cjs"
            }
        },
        "publish": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm publish",
                "cwd": "dist/packages/nestjs"
            }
        }
    }
}
